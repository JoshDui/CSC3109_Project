{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://app.example.com",
          "http://localhost:5173"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["Range", "Content-Type"]
      },
      "exposeHeaders": [
        "Accept-Ranges",
        "Content-Encoding",
        "Content-Length",
        "Content-Range",
        "ETag",
        "cf-cache-status"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
